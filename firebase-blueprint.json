{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "number" },
        "lastLoginAt": { "type": "number" }
      },
      "required": ["email", "createdAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "message", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Registered users"
    },
    "feedback/{feedbackId}": {
      "schema": { "$ref": "#/entities/Feedback" },
      "description": "Feedback messages"
    },
    "workspaces/{userId}": {
      "schema": "legacy",
      "description": "Stores user workspace data"
    }
  }
}
